# ── Sentiment Module Configuration ─────────────────────────────────────
# Copy this file to .env and adjust values as needed.

# Paths (relative to sentiment/ or absolute)
INPUT_FILE=output/sample_reviews.json
OUTPUT_FILE=output/analyzed_reviews.json

# Logging
ENABLE_LOGGING=true
LOG_DIR=logs
LOG_LEVEL=INFO

# VADER compound-score thresholds
POSITIVE_THRESHOLD=0.05
NEGATIVE_THRESHOLD=-0.05

# Minimum confidence to flag a review as "reliable"
CONFIDENCE_THRESHOLD=0.6
