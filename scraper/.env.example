# Scraper Module – Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must never be committed.

# ---------------------------------------------------------------------------
# Browser
# ---------------------------------------------------------------------------

# Run Chrome in headless mode (true/false)
HEADLESS=true

# Open browser in incognito mode (true/false)
INCOGNITO=true

# Custom User-Agent string (leave blank to use the default)
# USER_AGENT=Mozilla/5.0 ...

# Browser window dimensions (used when HEADLESS=false)
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# ---------------------------------------------------------------------------
# Timing
# ---------------------------------------------------------------------------

# Maximum seconds to wait for a page element to appear
PAGE_TIMEOUT=20

# Implicit wait fallback (seconds)
IMPLICIT_WAIT=5

# Pause duration (seconds) between scroll steps for infinite scroll pages
SCROLL_PAUSE=1.5

# ---------------------------------------------------------------------------
# Scraping limits
# ---------------------------------------------------------------------------

# Maximum products per keyword search
MAX_PRODUCTS=10

# Maximum reviews per product
MAX_REVIEWS=50

# Maximum search result pages to paginate
MAX_SEARCH_PAGES=3

# Maximum review pages to paginate per product
MAX_REVIEW_PAGES=5

# ---------------------------------------------------------------------------
# Retry
# ---------------------------------------------------------------------------

# Total retry attempts on transient failures (network, timeout, captcha)
RETRY_ATTEMPTS=3

# Initial delay (seconds) between retries; doubles exponentially
RETRY_DELAY=2.0

# ---------------------------------------------------------------------------
# Export
# ---------------------------------------------------------------------------

# Export data as JSON files (true/false)
EXPORT_JSON=true

# Export data as CSV files (true/false)
EXPORT_CSV=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Maximum log file size before rotation (bytes, default 5 MB)
LOG_MAX_BYTES=5242880

# Number of rotated log files to keep
LOG_BACKUP_COUNT=3
